# Tuneflow API
DATABASE_URL=sqlite+aiosqlite:///./data/tuneflow.db
PIPED_BASE_URL=https://pipedapi.kavin.rocks
CORS_ORIGINS=*

# Auth — first parent account is auto-created on startup if no users exist
JWT_SECRET=change-me-to-a-long-random-jwt-secret
BOOTSTRAP_USERNAME=admin
BOOTSTRAP_PASSWORD=changeme
BOOTSTRAP_DISPLAY_NAME=Parent

# LLM — OpenAI-compatible API (Ollama, LM Studio, OpenAI, etc.)
LLM_ENABLED=true
LLM_BASE_URL=http://192.168.1.100:11434/v1
LLM_API_KEY=
LLM_MODEL=llama3.2
LLM_TIMEOUT_SEC=120

# Used by docker-compose for Piped (optional self-host profile)
POSTGRES_PASSWORD=tuneflow-piped-secret
