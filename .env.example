# Tuneflow API
DATABASE_URL=sqlite+aiosqlite:///./data/tuneflow.db
PIPED_BASE_URL=https://api.piped.private.coffee
PIPED_FALLBACK_URLS=https://api.piped.private.coffee,https://pipedapi-libre.kavin.rocks,https://pipedapi.kavin.rocks
CORS_ORIGINS=*

# Auth — interactive setup creates the first local parent account on a fresh install.
# Enable bootstrap only for intentional headless/docker provisioning.
JWT_SECRET=change-me-to-a-long-random-jwt-secret
BOOTSTRAP_ENABLED=false
BOOTSTRAP_USERNAME=admin
BOOTSTRAP_PASSWORD=changeme
BOOTSTRAP_DISPLAY_NAME=Parent
BOOTSTRAP_IS_ADMIN=true

# Internet exposure hardening (sensible defaults; tune as needed)
TRUST_PROXY_HEADERS=false
DOCS_ENABLED=true
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SEC=900
SETUP_RATE_LIMIT_ATTEMPTS=5
SETUP_RATE_LIMIT_WINDOW_SEC=3600
PIN_RATE_LIMIT_ATTEMPTS=10
PIN_RATE_LIMIT_WINDOW_SEC=900
SETUP_MIN_PASSWORD_LENGTH=8

# LLM — OpenAI-compatible API (Ollama, LM Studio, OpenAI, etc.)
LLM_ENABLED=true
LLM_BASE_URL=http://192.168.1.100:11434/v1
LLM_API_KEY=
LLM_MODEL=llama3.2
LLM_TIMEOUT_SEC=120

# Audioscrobbler — per-user linking uses these app credentials (get keys from last.fm/api/account/create)
SCROBBLER_LASTFM_API_KEY=
SCROBBLER_LASTFM_API_SECRET=
# Optional Libre.fm (same API shape, separate app registration)
SCROBBLER_LIBREFM_API_KEY=
SCROBBLER_LIBREFM_API_SECRET=

# Used by docker-compose for Piped (optional self-host profile)
POSTGRES_PASSWORD=tuneflow-piped-secret

# Default API URL baked into the web UI build (browser must reach this address)
VITE_API_URL=http://localhost:8010

# Host ports when using docker compose (override if these clash)
API_PORT=8010
WEB_PORT=3010
